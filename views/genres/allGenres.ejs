<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('../partials/favicon') %>
    <title><%= title %></title>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <h1><%= title %></h1>
    <a href="/genres/add-genre"><button>+ Add genre</button></a>
    <ul>
      <% if (includeMissing) { %>
        <li><a href="/genres/missing">***MISSING</a></li>
      <% } %>
      <% genres.forEach((genre) => { %>
        <li><a href="/genres/<%= genre.url_path %>"><%= genre.genre %></a></li>
      <% }); %>
    </ul>
  </body>
</html>
