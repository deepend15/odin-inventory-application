<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('../partials/favicon') %>
    <title><%= title %>: <%= genre.genre %></title>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <h1>Genres > <%= title %> > <%= genre.genre %></h1>
    <%- include('../partials/errors') %>
    <%- include('../partials/dupes') %>
    <form action="/genres/<%= genre.url_path %>/edit" method="POST">
      <label for="genre">Genre name:</label>
      <input
        type="text"
        id="genre"
        name="genre"
        value="<%= genreInputValue %>"
        required
      />
      <button>Submit</button>
    </form>
    <p><a href="/genres/<%= genre.url_path %>">&lt;&lt; Back to genre</a></p>
  </body>
</html>
