<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('../partials/favicon') %>
    <link rel="stylesheet" href="/styles.css">
    <title><%= title %></title>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <h1>All movies > <%= title %></h1>
    <p>* = required field</p>
    <%- include('../partials/errors') %>
    <%- include('../partials/dupes') %>
    <form action="/movies/add-movie" method="POST">
      <p>
        <label for="title">*Title:</label>
        <input type="text" name="title" id="title" value="<%= titleValue %>" required/>
      </p>
      <p>
        <label for="studio">*Studio:</label>
        <select name="studio" id="studio" required>
            <option value="">--Select a studio--</option>
          <% studios.forEach((studio) => { %>
            <% if (studio.studio === studioValue) { %>
              <option selected><%= studio.studio %></option>
            <% } else { %>
              <option><%= studio.studio %></option>
            <% } %>
          <% }); %>
        </select>
      </p>
      <p>Don't see the studio you need? <a href="/studios/add-studio">Add a new studio</a></p>
      <p>
        <label for="genre1">*Primary genre:</label>
        <select name="genre1" id="genre1" required>
            <option value="">--Select a genre--</option>
          <% genres.forEach((genre) => { %>
            <% if (genre.genre === genre1Value) { %>
              <option selected><%= genre.genre %></option>
            <% } else { %>
              <option><%= genre.genre %></option>
            <% } %>
          <% }); %>
        </select>
      </p>
      <p>
        <label for="genre2">Secondary genre:</label>
        <select name="genre2" id="genre2">
            <option value="">--Select a genre--</option>
          <% genres.forEach((genre) => { %>
            <% if (genre.genre === genre2Value) { %>
              <option selected><%= genre.genre %></option>
            <% } else { %>
              <option><%= genre.genre %></option>
            <% } %>
          <% }); %>
        </select>
      </p>
      <p>Don't see the genre you need? <a href="/genres/add-genre">Add a new genre</a></p>
      <p>
        <label for="year">*Year of release:</label>
        <input
          type="number"
          name="year"
          id="year"
          min="1878"
          max="2500"
          value="<%= yearValue %>"
          required
        >
      </p>
      <p>
        <label for="stock">*Number in stock:</label>
        <input
          type="number"
          name="stock"
          id="stock"
          min="0"
          max="2000"
          value="<%= stockValue %>"
          required
        >
      </p>
      <button>Submit</button>
    </form>
    <p><a href="/movies">&lt;&lt; All movies</a></p>
  </body>
</html>
