<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <%- include('../partials/favicon') %>
    <link rel="stylesheet" href="/styles.css">
    <title><%= movie.title %></title>
  </head>
  <body>
    <%- include('../partials/nav') %>
    <h1><%= movie.title %>
    <% if (movie.genre_1 === "missing" || movie.studio === "missing") { %>
      <span class="missing-data">**missing data**</span>
    <% } %>
    </h1>
    <a href="/movies/<%= movie.movie_path %>/edit"><button>Edit movie</button></a>
    <a href="/movies/<%= movie.movie_path %>/delete"><button>Delete movie</button></a>
    <ul>
        <li>Year released: <%= movie.year %></li>
        <li>
          <%= movie.genre_1 === "missing" ? '**' : '' %>Genre:
          <a href="/genres/<%= movie.genre_1_path %>"><%= movie.genre_1 %></a><%= movie.genre_2 ? ',' : '' %>
          <% if (movie.genre_2) { %>
            <a href="/genres/<%= movie.genre_2_path %>"><%= movie.genre_2 %></a>
          <% } %>
        </li>
        <li>
          <%= movie.studio === "missing" ? '**' : '' %>Studio:
          <a href="/studios/<%= movie.studio_path %>"><%= movie.studio %></a>
        </li>
        <li>Number in stock: <%= movie.stock %></li>
    </ul>
    <a href="/movies">&lt;&lt; All movies</a>
  </body>
</html>
